NODE_ENV=development
PORT=3000
MONGO_URI="mongodb+srv://username:password@cluster0-xxxx.mongodb.net/database_name"
LOG_LEVEL=info
CORS_ORIGINS="http://localhost:5173,https://your-frontend.app"
FRONTEND_BASE_URL="http://localhost:5173"

# MySQL / MariaDB (Prisma)
DATABASE_URL="mysql://root:password@127.0.0.1:3306/commerce?allowPublicKeyRetrieval=true"
DATABASE_HOST="127.0.0.1"
DATABASE_PORT=3306
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="commerce"

# Cloudinary (upload ảnh sản phẩm)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
