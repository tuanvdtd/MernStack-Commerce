// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int               @id @default(autoincrement())
  email        String            @unique
  name         String
  password     String
  googleId     String?           @unique
  role         Role[]
  isActive     Boolean           @default(false)
  avatarUrl    String?
  phone        String?
  address      Address[]
  carts        Cart[]
  discountUses DiscountUserUse[]
  joinAt       DateTime          @default(now())
}

model Address {
  id     Int    @id @default(autoincrement())
  userId Int
  street String
  city   String
  user   User   @relation(fields: [userId], references: [id])
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

enum OtpPurpose {
  REGISTER
}

model Otp {
  id        Int        @id @default(autoincrement())
  email     String
  code      String
  purpose   OtpPurpose @default(REGISTER)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// SPU
model Product {
  id          String            @id @default(cuid())
  name        String            @db.VarChar(255)
  slug        String            @unique @db.VarChar(255)
  description String?           @db.Text
  categoryId  String
  category    Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants    ProductVariant[]
  discounts   DiscountProduct[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([categoryId])
}

// SKU
model ProductVariant {
  id            String                      @id @default(cuid())
  sku           String                      @unique @db.VarChar(100)
  price         Decimal                     @db.Decimal(12, 2)
  stockQuantity Int                         @default(0)
  productId     String
  product       Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  options       ProductVariantOptionValue[]
  cartItems     CartItem[]
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([productId])
}

model Option {
  id     String        @id @default(cuid())
  name   String        @unique @db.VarChar(100)
  values OptionValue[]
}

model OptionValue {
  id              String                      @id @default(cuid())
  value           String                      @db.VarChar(100)
  synonyms        Json?
  optionId        String
  option          Option                      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  productVariants ProductVariantOptionValue[]

  @@unique([optionId, value])
}

model ProductVariantOptionValue {
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  optionValueId    String
  optionValue      OptionValue    @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([productVariantId, optionValueId])
  @@index([optionValueId])
}

enum CartState {
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  PENDING   @map("pending")
  FAILED    @map("failed")
}

model Cart {
  id           String     @id @default(cuid())
  state        CartState  @default(ACTIVE)
  items        CartItem[]
  countProduct Int        @default(0)
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId, state])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity  Int
  price     Decimal        @db.Decimal(12, 2)
  name      String         @db.VarChar(255)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([variantId])
}

enum DiscountType {
  FIXED_AMOUNT @map("fixed_amount")
  PERCENTAGE   @map("percentage")
}

enum DiscountAppliesTo {
  ALL      @map("all")
  SPECIFIC @map("specific")
}

model Discount {
  id             String            @id @default(cuid())
  name           String            @db.VarChar(255)
  description    String            @db.Text
  type           DiscountType      @default(FIXED_AMOUNT)
  value          Decimal           @db.Decimal(12, 2)
  maxValue       Decimal           @db.Decimal(12, 2)
  code           String            @unique @db.VarChar(100)
  startDate      DateTime
  endDate        DateTime
  maxUses        Int
  usesCount      Int               @default(0)
  maxUsesPerUser Int
  minOrderValue  Decimal           @default(0) @db.Decimal(12, 2)
  isActive       Boolean           @default(true)
  appliesTo      DiscountAppliesTo
  products       DiscountProduct[]
  userUses       DiscountUserUse[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([startDate, endDate])
}

model DiscountProduct {
  discountId String
  productId  String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([discountId, productId])
  @@index([productId])
}

model DiscountUserUse {
  discountId String
  userId     Int
  usesCount  Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([discountId, userId])
  @@index([userId])
}
