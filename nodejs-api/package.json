{
  "name": "nodejs-api",
  "version": "1.0.0",
  "main": "server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "cross-env BUILD_MODE=dev nodemon --exec babel-node server.js",
    "dev:node": "cross-env BUILD_MODE=dev nodemon server.js",
    "clean": "rimraf build && mkdir build",
    "build-babel": "babel ./src -d ./build/src",
    "start": "cross-env BUILD_MODE=production babel-node server.js",
    "build": "npm run clean && npm run build-babel",
    "production": "npm run build && cross-env BUILD_MODE=production node ./build/src/server.js",
    "start:node": "cross-env BUILD_MODE=production node server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuanvdtd/nodejs-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tuanvdtd/nodejs-api/issues"
  },
  "homepage": "https://github.com/tuanvdtd/nodejs-api#readme",
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "accesscontrol": "^2.2.1",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "discord.js": "^14.24.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "mongoose": "^8.19.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "nodemon": "^3.1.10",
    "redis": "^5.9.0",
    "resend": "^6.5.2",
    "slugify": "^1.6.6",
    "streamifier": "^0.1.1",
    "uuid": "^13.0.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/node": "^7.28.0",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  }
}
